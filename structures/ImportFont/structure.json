{
  "_id": "importFont",
  "name": "Import as Font",
  "type": "importer",
  "tester": "return loadedApps.length > 0 && /\\.(ttf|otf|woff|woff2)$/i.test(input.name)",
  "inApp": true,
  "parameters": [
    {
      "name": "Source File",
      "display": "Font File",
      "type": "file",
      "helpText": "Select the file to import"
    }
  ]
}